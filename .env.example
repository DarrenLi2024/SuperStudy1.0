# =============================================
# SuperStudy 生产环境变量模板
# 复制为 .env 后填入真实值
# =============================================

# --- JWT ---
JWT_SECRET=your-random-64-char-jwt-secret-here-change-it

# --- MySQL ---
SPRING_DATASOURCE_URL=jdbc:mysql://db:3306/superstudy?useUnicode=true&characterEncoding=utf8mb4&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your-strong-db-password

# --- Redis ---
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379

# --- AI 大模型（必填）---
AI_LLM_PROVIDER=deepseek
AI_LLM_BASE_URL=https://api.deepseek.com/v1/chat/completions
AI_LLM_API_KEY=sk-your-deepseek-api-key
AI_LLM_MODEL=deepseek-chat
AI_LLM_TIMEOUT_MS=8000
AI_LLM_MAX_RETRIES=2
